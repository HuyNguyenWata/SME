# POSTGRES DATABASE
DATABASE_URL="your-database-url"

# APP CONFIG
PORT=3000
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN=900
JWT_REFRESH_SECRET="your-jwt-refresh-secret"
JWT_REFRESH_EXPIRES_IN=604800

# CLOUDINARY
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Meta App (Facebook/Instagram): a single platform-wide App ID/Secret is
# configured via Settings -> Facebook Login (stored in the Setting table as
# META_APP_ID/META_APP_SECRET/META_GRAPH_API_VERSION), not here. It powers both
# storefront "Login with Facebook" and admin Facebook Page/Instagram connect.

# Comma-separated emails allowed to view/edit the platform-wide Meta App config
# above (PUT/DELETE /auth/facebook-login-config). Store owners are NOT allowed
# even though they have role=ADMIN, since that config is shared by everyone.
PLATFORM_OWNER_EMAILS="admin@watasoft.com"

# AI CORE
AI_CORE_URL="http://localhost:8000"

# N8N
N8N_URL=n8n-url
N8N_WEBHOOK_ID=n8n-webhook-id
 
# Full webhook URL (optional)
N8N_WEBHOOK_URL=n8n-webhook-url
N8N_WEBHOOK_URL_INSTANT=your-n8n-webhook-url-instant
N8N_WEBHOOK_CREATE_CONTENT_URL=your-n8n-webhook-create-content-url

# REDIS
REDIS_HOST=your-redis-host
REDIS_PORT=your-redis-port
REDIS_PASSWORD=password
REDIS_TLS_ENABLED=false
REDIS_DB=0
REDIS_TTL_SECONDS=600