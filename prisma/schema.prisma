generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  role       String
  categoryId Int?     @map("category_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category          Category?          @relation(fields: [categoryId], references: [id])
  products          Product[]
  conversations     Conversation[]
  generatedContents GeneratedContent[]

  @@map("User")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  users      User[]
  rssSources RSSSource[]

  @@map("Category")
}

model Product {
  id                 Int       @id @default(autoincrement())
  userId             Int       @map("user_id")
  name               String
  description        String?
  price              Decimal   @db.Decimal(10, 2)
  quantity           Int
  unit               String
  sku                String?
  status             String
  specifications     Json?
  embeddingStatus    String?   @map("embedding_status")
  embeddingUpdatedAt DateTime? @map("embedding_updated_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  images             ProductImage[]
  comments           ProductComment[]
  inventoryHistories InventoryHistory[]

  @@map("Product")
}

model ProductImage {
  id          Int     @id @default(autoincrement())
  productId   Int     @map("product_id")
  url         String
  isThumbnail Boolean @default(false) @map("is_thumbnail")
  sortOrder   Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id])

  @@map("ProductImage")
}

model ProductComment {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  userName  String   @map("user_name")
  content   String
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("ProductComment")
}

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  chats Chat[]

  @@map("Conversation")
}

model Chat {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  role           String
  message        String
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("Chat")
}

model RSSSource {
  id         Int     @id @default(autoincrement())
  categoryId Int     @map("category_id")
  name       String
  url        String
  isActive   Boolean @default(true) @map("is_active")

  category Category @relation(fields: [categoryId], references: [id])

  @@map("RSSSource")
}

model GeneratedContent {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  content   String
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  socialPosts SocialPost[]

  @@map("GeneratedContent")
}

model SocialPlatform {
  id        Int      @id @default(autoincrement())
  name      String
  config    Json?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  socialPosts SocialPost[]

  @@map("SocialPlatform")
}

model SocialPost {
  id                 Int       @id @default(autoincrement())
  generatedContentId Int       @map("generated_content_id")
  platformId         Int       @map("platform_id")
  postId             String?   @map("post_id")
  publishedAt        DateTime? @map("published_at")
  status             String
  createdAt          DateTime  @default(now()) @map("created_at")

  generatedContent GeneratedContent @relation(fields: [generatedContentId], references: [id])
  platform         SocialPlatform   @relation(fields: [platformId], references: [id])
  comments         SocialComment[]

  @@map("SocialPost")
}

model SocialComment {
  id           Int      @id @default(autoincrement())
  socialPostId Int      @map("social_post_id")
  author       String
  content      String
  createdAt    DateTime @default(now()) @map("created_at")

  socialPost SocialPost @relation(fields: [socialPostId], references: [id])

  @@map("SocialComment")
}

model InventoryHistory {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  type           String
  changeQuantity Int      @map("change_quantity")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("InventoryHistory")
}

model PromptTemplate {
  id       Int     @id @default(autoincrement())
  name     String
  prompt   String
  isActive Boolean @default(true) @map("is_active")
  type     String

  @@map("PromptTemplate")
}

model Setting {
  key         String  @id
  value       String
  description String?

  @@map("Setting")
}

model AIJob {
  id         Int       @id @default(autoincrement())
  type       String
  status     String
  targetId   Int?      @map("target_id")
  error      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  finishedAt DateTime? @map("finished_at")

  @@map("AIJob")
}
