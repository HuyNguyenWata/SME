generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  slug              String             @unique
  password          String?
  name              String
  description       String?
  logoUrl           String?            @map("logo_url")
  role              String
  categoryId        Int?               @map("category_id")
  isActive          Boolean            @default(true) @map("is_active")
  facebookId        String?            @unique @map("facebook_id")
  provider          String             @default("LOCAL")
  avatarUrl         String?            @map("avatar_url")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  conversations     Conversation[]
  generatedContents GeneratedContent[]
  products          Product[]
  category          Category?          @relation(fields: [categoryId], references: [id])
  newsAPIConfigs    NewsAPIConfig[]
  socialAccounts    SocialAccount[]
  customers         Customer[]         @relation("StoreCustomers")

  @@map("User")
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String
  rssSources RSSSource[]
  users      User[]

  @@map("Category")
}

model Customer {
  id        Int      @id @default(autoincrement())
  storeId   Int      @map("store_id")
  email     String
  password  String
  name      String
  phone     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store         User           @relation("StoreCustomers", fields: [storeId], references: [id])
  conversations Conversation[]

  @@unique([email, storeId])
  @@map("Customer")
}

model Product {
  id                 Int                @id @default(autoincrement())
  userId             Int                @map("user_id")
  name               String
  description        String?
  price              Decimal            @db.Decimal(10, 2)
  quantity           Int
  unit               String
  sku                String?
  status             String
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  embeddingStatus    String?            @map("embedding_status")
  embeddingUpdatedAt DateTime?          @map("embedding_updated_at")
  specifications     Json?
  hasBeenOut         Boolean            @default(false) @map("has_been_out")
  lowStockThreshold  Int                @default(10) @map("low_stock_threshold")
  expiryDate         DateTime?          @map("expiry_date")
  inventoryHistories InventoryHistory[]
  marketingProducts  MarketingProduct[]
  user               User               @relation(fields: [userId], references: [id])
  comments           ProductComment[]
  images             ProductImage[]
  socialCalendars    SocialCalendar[]
  socialPosts        SocialPost[]

  @@map("Product")
}

model ProductImage {
  id           Int       @id @default(autoincrement())
  productId    Int       @map("product_id")
  url          String
  isThumbnail  Boolean   @default(false) @map("is_thumbnail")
  sortOrder    Int       @default(0) @map("sort_order")
  alt_text     String?
  ai_generated Boolean?  @default(false)
  created_at   DateTime? @default(now())
  product      Product   @relation(fields: [productId], references: [id])

  @@map("ProductImage")
}

model ProductComment {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  userName  String   @map("user_name")
  content   String
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id])

  @@map("ProductComment")
}

model Conversation {
  id               Int      @id @default(autoincrement())
  storeId          Int?     @map("store_id")
  customerId       Int?     @map("customer_id")
  guestId          String?  @map("guest_id")
  title            String
  createdAt        DateTime @default(now()) @map("created_at")
  summary          String?
  updatedAt        DateTime @updatedAt @map("updated_at")
  contextProductId Int?     @map("context_product_id")
  chats            Chat[]
  store            User?    @relation(fields: [storeId], references: [id])
  customer         Customer? @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([guestId])
  @@map("Conversation")
}

model Chat {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  role           String
  message        String
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("Chat")
}

model RSSSource {
  id         Int      @id @default(autoincrement())
  categoryId Int      @map("category_id")
  name       String
  url        String
  isActive   Boolean  @default(true) @map("is_active")
  category   Category @relation(fields: [categoryId], references: [id])

  @@map("RSSSource")
}

model GeneratedContent {
  id                Int              @id @default(autoincrement())
  title             String
  createdAt         DateTime         @default(now()) @map("created_at")
  relevant          Boolean?
  reason            String?
  facebook_post     String?
  website_article   String?
  hashtags          Json?
  seo_keywords      Json?
  source_article_id Int?
  userId            Int?             @map("user_id")
  instagram_post    String?
  SourceArticle     SourceArticle?   @relation(fields: [source_article_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user              User?            @relation(fields: [userId], references: [id])
  socialCalendars   SocialCalendar[]
  socialPosts       SocialPost[]

  @@index([createdAt], map: "idx_generatedcontent_created")
  @@map("GeneratedContent")
}

model SourceArticle {
  id               Int                @id @default(autoincrement())
  external_id      String?            @unique
  title            String?
  description      String?
  url              String?
  source_name      String?
  language         String?
  raw_data         Json?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  published_at     DateTime?
  image_url        String?
  author           String?
  content          String?
  category         String?
  country          String?
  video_url        String?
  source_id        String?
  source_url       String?
  source_icon      String?
  source_priority  Int?
  keywords         String[]
  creator          String[]
  datatype         String?
  fetched_at       DateTime?          @db.Timestamptz(6)
  duplicate        Boolean?
  GeneratedContent GeneratedContent[]
}

model SocialAccount {
  id              Int            @id @default(autoincrement())
  userId          Int            @map("user_id")
  platformId      Int            @map("platform_id")
  accountName     String?        @map("account_name")
  avatarUrl       String?        @map("avatar_url")
  accountId       String         @map("account_id")
  pageId          String?        @map("page_id")
  instagramId     String?        @map("instagram_id")
  accessToken     String         @map("access_token")
  refreshToken    String?        @map("refresh_token")
  tokenExpiresAt  DateTime?      @map("token_expires_at")
  appId           String?        @map("app_id")
  appSecret       String?        @map("app_secret")
  webhookSecret   String?        @map("webhook_secret")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user            User           @relation(fields: [userId], references: [id])
  platform        SocialPlatform @relation(fields: [platformId], references: [id])
  socialPosts     SocialPost[]

  @@map("SocialAccount")
}

model SocialPlatform {
  id              Int              @id @default(autoincrement())
  name            String
  config          Json?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  socialCalendars SocialCalendar[]
  socialPosts     SocialPost[]
  socialAccounts  SocialAccount[]

  @@map("SocialPlatform")
}

model SocialPost {
  id                 Int              @id @default(autoincrement())
  generatedContentId Int              @map("generated_content_id")
  postId             String?          @map("post_id")
  publishedAt        DateTime?        @map("published_at")
  status             String
  createdAt          DateTime         @default(now()) @map("created_at")
  platformId         Int              @map("platform_id")
  accountId          Int?             @map("account_id")
  permalink          String?
  rawResponse        Json?            @map("raw_response")
  lastSyncAt         DateTime?        @map("last_sync_at")
  commentsCount      Int              @default(0) @map("comments_count")
  likesCount         Int              @default(0) @map("likes_count")
  sharesCount        Int              @default(0) @map("shares_count")
  comments           SocialComment[]
  generatedContent   GeneratedContent @relation(fields: [generatedContentId], references: [id])
  platform           SocialPlatform   @relation(fields: [platformId], references: [id])
  account            SocialAccount?   @relation(fields: [accountId], references: [id])
  productId          Int?             @map("product_id")
  socialCalendarId   Int?             @map("social_calendar_id")
  product            Product?         @relation(fields: [productId], references: [id])
  socialCalendar     SocialCalendar?  @relation(fields: [socialCalendarId], references: [id])

  @@index([postId], map: "idx_socialpost_postid")
  @@map("SocialPost")
}

model SocialComment {
  id           Int        @id @default(autoincrement())
  socialPostId Int        @map("social_post_id")
  author       String
  content      String
  createdAt    DateTime   @default(now()) @map("created_at")
  externalId   String?    @unique @map("external_id")
  socialPost   SocialPost @relation(fields: [socialPostId], references: [id])

  @@map("SocialComment")
}

model InventoryHistory {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  type           String
  changeQuantity Int      @map("change_quantity")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  product        Product  @relation(fields: [productId], references: [id])

  @@map("InventoryHistory")
}

model PromptTemplate {
  id          Int       @id @default(autoincrement())
  name        String
  prompt      String
  type        String
  isActive    Boolean   @default(true) @map("is_active")
  version     Int?      @default(1)
  description String?
  model       String?
  temperature Decimal?  @db.Decimal(3, 2)
  top_p       Decimal?  @db.Decimal(3, 2)
  created_at  DateTime? @default(now())
  updated_at  DateTime?

  @@map("PromptTemplate")
}

model Setting {
  key         String  @id
  value       String
  description String?

  @@map("Setting")
}

model AIJob {
  id            Int       @id @default(autoincrement())
  type          String
  status        String
  targetId      Int?      @map("target_id")
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  finishedAt    DateTime? @map("finished_at")
  workflow_name String?
  node_name     String?
  model         String?
  request       Json?
  response      Json?
  input_tokens  Int?
  output_tokens Int?
  cost          Decimal?  @db.Decimal(10, 6)
  duration_ms   Int?
  retry         Int?      @default(0)

  @@map("AIJob")
}

model MarketingProduct {
  id                Int       @id @default(autoincrement())
  productId         Int       @map("product_id")
  sellingPoints     Json?     @map("selling_points")
  targetCustomer    String?   @map("target_customer")
  promotionText     String?   @map("promotion_text")
  isFeatured        Boolean   @default(false) @map("is_featured")
  priority          Int       @default(0)
  lastPostedAt      DateTime? @map("last_posted_at")
  postFrequencyDays Int?      @map("post_frequency_days")
  createdAt         DateTime  @default(now()) @map("created_at")
  tone_of_voice     String?
  brand_voice       String?
  marketing_goal    String?
  pain_points       Json?
  forbidden_words   Json?
  seasonal_keywords Json?
  product           Product   @relation(fields: [productId], references: [id])

  @@map("MarketingProduct")
}

model Campaign {
  id              Int              @id @default(autoincrement())
  name            String
  startDate       DateTime?        @map("start_date")
  endDate         DateTime?        @map("end_date")
  status          String
  createdAt       DateTime         @default(now()) @map("created_at")
  description     String?
  budget          Decimal?         @db.Decimal(12, 2)
  objective       String?
  socialCalendars SocialCalendar[]

  @@map("Campaign")
}

model SocialCalendar {
  id                 Int               @id @default(autoincrement())
  productId          Int?              @map("product_id")
  campaignId         Int?              @map("campaign_id")
  platformId         Int               @map("platform_id")
  publishAt          DateTime?         @map("publish_at")
  status             String
  generatedContentId Int?              @map("generated_content_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  timezone           String?
  retry_count        Int?              @default(0)
  failed_reason      String?
  published_at       DateTime?
  campaign           Campaign?         @relation(fields: [campaignId], references: [id])
  generatedContent   GeneratedContent? @relation(fields: [generatedContentId], references: [id])
  platform           SocialPlatform    @relation(fields: [platformId], references: [id])
  product            Product?          @relation(fields: [productId], references: [id])
  socialPosts        SocialPost[]

  @@map("SocialCalendar")
}

model NewsCategory {
  id             Int             @id @default(autoincrement())
  name           String
  newsAPIConfigs NewsAPIConfig[]

  @@map("NewsCategory")
}

model NewsAPIConfig {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  name             String
  apiKey           String   @map("api_key")
  keyword          String?
  categoryId       Int?     @map("category_id")
  language         String   @default("en")
  targetPostCount  Int      @default(10) @map("target_post_count")
  loopHour         Int      @default(1) @map("loop_hour")
  imageRequirement Int      @default(1) @map("image_requirement")
  isActive         Boolean  @default(true) @map("is_active")
  lastRunAt        DateTime? @map("last_run_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  category NewsCategory? @relation(fields: [categoryId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@index([isActive, lastRunAt], map: "idx_newsapiconfig_active_lastrun")
  @@map("NewsAPIConfig")
}
